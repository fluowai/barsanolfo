# ============================================
# BARSA ADVOCACIA - CONFIGURAÇÃO DE AMBIENTE
# ============================================
# IMPORTANTE: Nunca commitr este arquivo com valores reais!
# Use: cp .env.example .env e preencha com seus valores

# ============================================
# SERVIDOR
# ============================================
PORT=5032
NODE_ENV=development
LOG_LEVEL=info

# ============================================
# BANCO DE DADOS
# ============================================
# SQLite para desenvolvimento
DATABASE_URL=file:./dev.db

# PostgreSQL para produção (comentado)
# DATABASE_URL=postgresql://user:password@localhost:5432/barsa_db

# ============================================
# AUTENTICAÇÃO (CRÍTICO - GERAR NOVO EM PRODUÇÃO)
# ============================================
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=GERAR_COM_CRYPTO_EM_PRODUÇÃO
JWT_EXPIRATION=24h

# ============================================
# SUPABASE (Opcional - para sync na nuvem)
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# ============================================
# DATAJUD (Consulta de Processos)
# ============================================
DATAJUD_API_KEY=

# ============================================
# GEMINI API (IA para análise)
# ============================================
GEMINI_API_KEY=

# ============================================
# EMAIL (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-app-google
SMTP_FROM=noreply@barsaadvocacia.com.br

# ============================================
# WHATSAPP
# ============================================
WHATSAPP_PHONE=5511987654321
WHATSAPP_WEBHOOK_URL=

# ============================================
# CORS - URLs PERMITIDAS
# ============================================
ALLOWED_ORIGINS=http://localhost:5032,http://localhost:5033,http://localhost:3001

# ============================================
# VERCEL (Produção)
# ============================================
# VERCEL_ENV=production
# VERCEL_URL=seu-site.vercel.app
